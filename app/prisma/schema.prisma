generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Category {
  FAMILY
  FRIEND
  WORK
  OTHER
}

model Contact {
  id                 String        @id @default(cuid())
  name               String
  phone              String?
  category           Category      @default(FRIEND)
  intervalDays       Int           @default(30)
  lastContactedAt    DateTime?
  createdAt          DateTime      @default(now())
  lastReminderSentAt DateTime?
  isActive           Boolean       @default(true)
  notes              String?
  interactions       Interaction[]
}

model Interaction {
  id        String   @id @default(cuid())
  contact   Contact  @relation(fields: [contactId], references: [id])
  contactId String
  notedAt   DateTime @default(now())
  note      String?
}

model Setting {
  id                 Int     @id @default(1)  // singleton row
  upcomingCount      Int     @default(2)      // combien d’“Upcoming” (Overdue/Today illimités)
  defaultFamilyDays  Int     @default(7)
  defaultFriendDays  Int     @default(30)
  defaultWorkDays    Int     @default(14)
  defaultOtherDays   Int     @default(21)
  sendEmailDigest    Boolean @default(true)   // on/off global pour l’email (WhatsApp plus tard)
  sendWhatsappDigest Boolean @default(false)  // on/off global pour WhatsApp (placeholder)
}